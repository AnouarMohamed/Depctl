{
  "version": "0.1",
  "project": {
    "name": "example-next-app",
    "root": "/srv/example-next-app"
  },
  "preset": "compose-traefik",
  "domain": "app.example.com",
  "publicService": "web",
  "runtime": {
    "name": "node",
    "framework": "nextjs",
    "confidence": 0.93
  },
  "services": [
    {
      "name": "web",
      "type": "app",
      "build": ".",
      "internalPort": 3000,
      "public": true
    },
    {
      "name": "postgres",
      "type": "database",
      "image": "postgres:16",
      "public": false,
      "volume": "postgres_data"
    }
  ],
  "env": {
    "required": [
      "DATABASE_URL",
      "NEXTAUTH_SECRET",
      "NEXTAUTH_URL"
    ],
    "sensitive": [
      "NEXTAUTH_SECRET"
    ]
  },
  "generatedFiles": [
    ".deploy/Dockerfile",
    ".deploy/.dockerignore",
    ".deploy/docker-compose.yml",
    ".deploy/.env.example",
    ".deploy/scripts/deploy.sh",
    ".deploy/scripts/rollback.sh",
    ".deploy/ci/github-actions.yml"
  ],
  "actions": [
    {
      "type": "create_network",
      "name": "web"
    },
    {
      "type": "compose_up",
      "file": ".deploy/docker-compose.yml"
    }
  ],
  "warnings": [
    "No health endpoint detected.",
    "Database migration is not automated. Run it manually after first deploy."
  ],
  "manualSteps": [
    "Create DNS A record for app.example.com pointing to this VPS.",
    "Fill real secret values in .env on the VPS.",
    "Review .deploy/docker-compose.yml before applying."
  ]
}
