# Generated by depctl
# Source plan: .deploy/plan.json
# Review before applying.

services:
{{range .Services}}
  {{.Name}}:
    {{if eq .Type "app"}}
    build:
      context: ..
      dockerfile: Dockerfile
    restart: unless-stopped
    {{if eq $.Preset "compose-traefik"}}
    networks:
      - proxy_net
      - app_net
    {{else}}
    ports:
      - "{{.InternalPort}}:{{.InternalPort}}"
    networks:
      - app_net
    {{end}}
    env_file:
      - ../.env
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:{{.InternalPort}}/ || curl -fsS http://127.0.0.1:{{.InternalPort}}/ || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
    {{if eq $.Preset "compose-traefik"}}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.{{$.Project.Name}}.rule=Host(`{{$.Domain}}`)"
      - "traefik.http.routers.{{$.Project.Name}}.entrypoints=websecure"
      - "traefik.http.routers.{{$.Project.Name}}.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{$.Project.Name}}.loadbalancer.server.port={{.InternalPort}}"
    {{end}}
    {{else if eq .Type "database"}}
    image: {{.Image}}
    restart: unless-stopped
    networks:
      - app_net
    env_file:
      - ../.env
    {{if .Volume}}
    {{if eq .Name "postgres"}}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    {{else if eq .Name "mysql"}}
    volumes:
      - mysql_data:/var/lib/mysql
    {{else if eq .Name "redis"}}
    volumes:
      - redis_data:/data
    {{end}}
    {{end}}
    {{end}}

{{end}}

networks:
  {{if eq $.Preset "compose-traefik"}}
  proxy_net:
    external: true
    name: web
  {{end}}
  app_net:
    driver: bridge

{{$hasVol := false}}
{{range .Services}}{{if .Volume}}{{$hasVol = true}}{{end}}{{end}}
{{if $hasVol}}
volumes:
  {{range .Services}}
  {{if .Volume}}
  {{.Volume}}:
  {{end}}
  {{end}}
{{end}}
