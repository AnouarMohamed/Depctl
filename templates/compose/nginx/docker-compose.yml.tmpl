# Generated by depctl
# Source plan: .deploy/plan.json
# Review before applying.

services:
{{range .Services}}
  {{.Name}}:
    {{if eq .Type "app"}}
    build:
      context: {{.Build}}
      dockerfile: Dockerfile
    restart: unless-stopped
    networks:
      - app_net
    env_file:
      - .env
    {{else if eq .Type "database"}}
    image: {{.Image}}
    restart: unless-stopped
    networks:
      - app_net
    env_file:
      - .env
    {{if .Volume}}
    {{if eq .Name "postgres"}}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    {{else if eq .Name "mysql"}}
    volumes:
      - mysql_data:/var/lib/mysql
    {{else if eq .Name "redis"}}
    volumes:
      - redis_data:/data
    {{end}}
    {{end}}
    {{end}}

{{end}}

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./.deploy/nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
      - certs:/etc/nginx/certs:ro
    networks:
      - app_net

networks:
  app_net:
    driver: bridge

{{$hasVol := false}}
{{range .Services}}{{if .Volume}}{{$hasVol = true}}{{end}}{{end}}
{{if or $hasVol true}}
volumes:
  certs:
  {{range .Services}}
  {{if .Volume}}
  {{.Volume}}:
  {{end}}
  {{end}}
{{end}}
