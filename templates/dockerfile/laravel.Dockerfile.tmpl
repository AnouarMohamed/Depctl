# Stage 1: Build frontends if package.json exists
FROM node:20-alpine AS frontend-builder
WORKDIR /app
COPY package.json {{if eq .Build.PackageManager "pnpm"}}pnpm-lock.yaml{{else if eq .Build.PackageManager "yarn"}}yarn.lock{{else}}package-lock.json{{end}} ./ 2>/dev/null || true
COPY . .
RUN \
  if [ -f package.json ]; then \
    npm install && npm run build; \
  else \
    echo "No frontend dependencies found, skipping build."; \
  fi

# Stage 2: Production PHP runner with Nginx
FROM php:8.2-fpm-alpine AS runner

# Install system dependencies
RUN apk add --no-cache \
    nginx \
    supervisor \
    libpng-dev \
    libxml2-dev \
    libzip-dev \
    zip \
    unzip \
    curl \
    oniguruma-dev

# Install PHP extensions
RUN docker-php-ext-install pdo_mysql pdo_pgsql mbstring exif pcntl bcmath gd zip opcache

# Install Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html

# Copy project files
COPY . .
COPY --from=frontend-builder /app/public/build ./public/build 2>/dev/null || true

# Run composer install
ENV COMPOSER_ALLOW_SUPERUSER=1
RUN composer install --no-dev --optimize-autoloader --no-interaction

# Set directory permissions for Laravel
RUN chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache

# Copy Nginx configuration
COPY .deploy/nginx/default.conf /etc/nginx/http.d/default.conf 2>/dev/null || true

# Expose web port
EXPOSE 80

# Run services via supervisord
CMD ["php", "artisan", "octane:start", "--host=0.0.0.0", "--port=80"]
