# Base image
FROM node:20-alpine AS base

# Stage 1: Install all dependencies (including dev)
FROM base AS deps
RUN apk add --no-cache libc6-compat
WORKDIR /app
COPY package.json {{if eq .Build.PackageManager "pnpm"}}pnpm-lock.yaml{{else if eq .Build.PackageManager "yarn"}}yarn.lock{{else if eq .Build.PackageManager "bun"}}bun.lockb{{else}}package-lock.json{{end}} ./
RUN \
  if [ -f pnpm-lock.yaml ]; then corepack enable pnpm && pnpm i --frozen-lockfile; \
  elif [ -f yarn.lock ]; then yarn install --frozen-lockfile; \
  elif [ -f bun.lockb ]; then corepack enable bun && bun install --frozen-lockfile; \
  else npm ci; \
  fi

# Stage 2: Compile (for TypeScript/NestJS if build command is defined)
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN \
  if [ -n "{{.Build.BuildCommand}}" ]; then {{.Build.BuildCommand}}; \
  else echo "No build command defined, skipping."; \
  fi

# Stage 3: Clean install production dependencies only
FROM base AS prod-deps
WORKDIR /app
COPY package.json {{if eq .Build.PackageManager "pnpm"}}pnpm-lock.yaml{{else if eq .Build.PackageManager "yarn"}}yarn.lock{{else if eq .Build.PackageManager "bun"}}bun.lockb{{else}}package-lock.json{{end}} ./
RUN \
  if [ -f pnpm-lock.yaml ]; then corepack enable pnpm && pnpm i --prod --frozen-lockfile; \
  elif [ -f yarn.lock ]; then yarn install --production --frozen-lockfile; \
  elif [ -f bun.lockb ]; then corepack enable bun && bun install --production --frozen-lockfile; \
  else npm ci --only=production; \
  fi

# Stage 4: Final runner
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nodeapp

# Copy production node_modules and code
COPY --from=prod-deps /app/node_modules ./node_modules
COPY --from=builder --chown=nodeapp:nodejs /app ./

USER nodeapp
EXPOSE {{.Network.InternalPort}}
ENV PORT={{.Network.InternalPort}}

CMD [{{if eq .Build.PackageManager "bun"}}"bun"{{else}}"node"{{end}}, "{{if eq .Runtime.Framework "nestjs"}}dist/main.js{{else}}index.js{{end}}"]
