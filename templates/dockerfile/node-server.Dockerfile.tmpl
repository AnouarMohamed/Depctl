FROM node:20-alpine AS base

WORKDIR /app
ENV NODE_ENV=production
ENV PORT={{.Network.InternalPort}}

RUN apk add --no-cache dumb-init

COPY . .

RUN set -eux; \
  if [ -f pnpm-lock.yaml ]; then corepack enable pnpm && pnpm install --frozen-lockfile; \
  elif [ -f yarn.lock ]; then corepack enable yarn && yarn install --frozen-lockfile; \
  elif [ -f bun.lockb ]; then npm install -g bun && bun install --frozen-lockfile; \
  elif [ -f package-lock.json ]; then npm ci; \
  else npm install; \
  fi; \
  if [ -n "{{.Build.BuildCommand}}" ]; then {{.Build.BuildCommand}}; fi; \
  if [ -f pnpm-lock.yaml ]; then pnpm prune --prod; \
  elif [ -f yarn.lock ]; then yarn workspaces focus --production 2>/dev/null || yarn install --production --frozen-lockfile; \
  elif [ -f package-lock.json ]; then npm prune --omit=dev; \
  else npm prune --omit=dev || true; \
  fi

RUN addgroup -S app && adduser -S app -G app && chown -R app:app /app
USER app

EXPOSE {{.Network.InternalPort}}

ENTRYPOINT ["dumb-init", "--"]
CMD ["sh", "-c", "{{.Build.StartCommand}}"]
