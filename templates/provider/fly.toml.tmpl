app = "{{.Target.AppName}}"
primary_region = "{{.Target.Region}}"

[build]
  dockerfile = "Dockerfile"

[env]
  PORT = "{{.Network.InternalPort}}"

[http_service]
  internal_port = {{.Network.InternalPort}}
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 1
  processes = ["app"]

  [[http_service.checks]]
    interval = "15s"
    timeout = "3s"
    grace_period = "20s"
    method = "GET"
    path = "/"
