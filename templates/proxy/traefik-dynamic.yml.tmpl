# Generated by depctl
# Traefik dynamic configuration for {{.Domain}}

http:
  routers:
    {{.Project.Name}}-router:
      rule: "Host(`{{.Domain}}`)"
      service: {{.Project.Name}}-service
      entryPoints:
        - websecure
      tls:
        certResolver: letsencrypt

  services:
    {{.Project.Name}}-service:
      loadBalancer:
        servers:
          - url: "http://{{.PublicService}}:{{(index .Services 0).InternalPort}}"
