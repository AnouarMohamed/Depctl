#!/bin/bash
# Generated by depctl

set -euo pipefail

# Ensure we are in the project root
cd "$(dirname "$0")/../.."

TIMESTAMP=$(date +%Y%m%d%H%M%S)
BACKUP_DIR=".deploy/backups/$TIMESTAMP"

echo "💾 Creating backup in $BACKUP_DIR..."
mkdir -p "$BACKUP_DIR"

cp .deploy/docker-compose.yml "$BACKUP_DIR/"
if [ -f .deploy/.env ]; then
    cp .deploy/.env "$BACKUP_DIR/"
fi

# If there's a database, we should ideally dump it
{{range .Services}}
{{if eq .Type "database"}}
echo "🗄️ Dumping {{.Name}}..."
{{if eq $.Preset "swarm-traefik"}}
CONTAINER_ID=$(docker ps -q -f name={{$.Project.Name}}_{{.Name}} | head -n 1)
if [ -n "$CONTAINER_ID" ]; then
  {{if eq .Name "postgres"}}
  docker exec -T "$CONTAINER_ID" pg_dumpall -U postgres > "$BACKUP_DIR/{{.Name}}_dump.sql"
  {{else if eq .Name "mysql"}}
  docker exec -T "$CONTAINER_ID" mysqldump --all-databases -u root -p"$MYSQL_ROOT_PASSWORD" > "$BACKUP_DIR/{{.Name}}_dump.sql"
  {{end}}
else
  echo "⚠️ Database container for {{.Name}} not found on this node; backup skipped."
fi
{{else}}
  {{if eq .Name "postgres"}}
  docker compose -f .deploy/docker-compose.yml exec -T {{.Name}} pg_dumpall -U postgres > "$BACKUP_DIR/{{.Name}}_dump.sql"
  {{else if eq .Name "mysql"}}
  docker compose -f .deploy/docker-compose.yml exec -T {{.Name}} mysqldump --all-databases -u root -p"$MYSQL_ROOT_PASSWORD" > "$BACKUP_DIR/{{.Name}}_dump.sql"
  {{end}}
{{end}}
{{end}}
{{end}}

echo "✅ Backup complete!"
