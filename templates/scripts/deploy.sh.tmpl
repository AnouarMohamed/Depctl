#!/bin/bash
# Generated by depctl

set -euo pipefail

# Ensure we are in the project root
cd "$(dirname "$0")/../.."

echo "🚀 Starting deployment for {{.Domain}}..."

# 1. Run validation
echo "🔍 Validating deployment kit..."
# Assuming depctl is in the PATH or we use the binary
# For now, we'll just check if files exist
if [ ! -f .deploy/docker-compose.yml ]; then
    echo "❌ .deploy/docker-compose.yml not found!"
    exit 1
fi

# 2. Pull/Build
echo "📦 Building images..."
{{if eq .Preset "swarm-traefik"}}
docker compose -f .deploy/docker-compose.yml build
{{else}}
docker compose -f .deploy/docker-compose.yml build --pull
{{end}}

# 3. Up
echo "🆙 Starting containers..."
{{if eq .Preset "swarm-traefik"}}
docker stack deploy -c .deploy/docker-compose.yml {{.Project.Name}}
{{else}}
docker compose -f .deploy/docker-compose.yml up -d
{{end}}

# 4. Healthcheck
echo "🏥 Checking health..."
# Simple check for now
{{if eq .Preset "swarm-traefik"}}
docker stack services {{.Project.Name}}
{{else}}
docker compose -f .deploy/docker-compose.yml ps
{{end}}

echo "✅ Deployment complete!"
