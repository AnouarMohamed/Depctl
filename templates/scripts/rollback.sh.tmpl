#!/bin/bash
# Generated by depctl

set -euo pipefail

# Ensure we are in the project root
cd "$(dirname "$0")/../.."

echo "⏪ Rolling back deployment for {{.Domain}}..."

# Simple rollback: just restart the previous state if possible,
# or just re-run compose up.
# Real rollback would involve switching to a backup folder.

{{if eq .Preset "swarm-traefik"}}
docker stack deploy -c .deploy/docker-compose.yml {{.Project.Name}}
{{else}}
docker compose -f .deploy/docker-compose.yml up -d
{{end}}

echo "✅ Rollback attempted."
